  "item": [
    {
      "name": "1. Create Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const body = pm.response.json();",
              "",
              "    if (body.id) {",
              "        pm.collectionVariables.set('customerId', body.id);",
              "    }",
              "",
              "      if (body.country) {",
              "        pm.collectionVariables.set(\"countryName\", body.country);",
              "    }",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstName\": \"Alex\",\n    \"lastName\": \"Lee\",\n    \"email\": \"alex@example.com\",\n    \"country\": \"malaysia\",\n    \"dateOfBirth\": \"1990-01-15\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/customers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "customers"
          ]
        },
        "description": "Creates a new customer record. Service method is annotated with @Transactional."
      },
      "response": []
    },
    {
      "name": "2. Update Customer",
      "request": {
        "method": "PUT",
        "header": [
          {
