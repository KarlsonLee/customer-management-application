          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstName\": \"Alex\",\n    \"lastName\": \"Lee\",\n    \"email\": \"elex2@example.com\",\n    \"country\": \"Malaysia\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "customers",
            "{{customerId}}"
          ]
        },
        "description": "Updates an existing customer. Service method is annotated with @Transactional."
      },
      "response": []
    },
    {
